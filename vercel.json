{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/mcp/(.*)",
      "dest": "api/mcp.ts"
    },
    {
      "src": "/mcp",
      "dest": "api/mcp.ts"
    },
    {
      "src": "/ping",
      "dest": "api/mcp.ts"
    },
    {
      "src": "/.well-known/(.*)",
      "dest": "api/mcp.ts"
    }
  ]
}
